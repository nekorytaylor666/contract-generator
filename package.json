{
  "name": "contract-builder",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^5",
      "@types/bun": "^1.3.4",
      "hono": "^4.8.2",
      "@trpc/server": "^11.7.2",
      "better-auth": "^1.4.9",
      "ai": "^6.0.3",
      "@trpc/tanstack-react-query": "^11.7.2",
      "@trpc/client": "^11.7.2",
      "@ai-sdk/react": "^3.0.3",
      "@better-auth/expo": "^1.4.9"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:native": "turbo -F native dev",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "db:push": "turbo -F @contract-builder/db db:push",
    "db:studio": "turbo -F @contract-builder/db db:studio",
    "db:generate": "turbo -F @contract-builder/db db:generate",
    "db:migrate": "turbo -F @contract-builder/db db:migrate",
    "db:start": "turbo -F @contract-builder/db db:start",
    "db:watch": "turbo -F @contract-builder/db db:watch",
    "db:stop": "turbo -F @contract-builder/db db:stop",
    "db:down": "turbo -F @contract-builder/db db:down",
    "deploy": "turbo -F @contract-builder/infra deploy",
    "destroy": "turbo -F @contract-builder/infra destroy",
    "check": "ultracite check",
    "fix": "ultracite fix"
  },
  "dependencies": {
    "@contract-builder/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.12",
    "@cloudflare/workers-types": "^4.20251213.0",
    "@contract-builder/config": "workspace:*",
    "@types/bun": "catalog:",
    "turbo": "^2.6.3",
    "typescript": "catalog:",
    "ultracite": "7.1.1"
  },
  "packageManager": "bun@1.3.11"
}
